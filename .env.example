# Ollama HTTP API (default: local install)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Models — pull with: ollama pull <name>
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Where Cluny stores SQLite + Chroma.
# Relative paths resolve next to pyproject.toml; use an absolute path for a fixed folder e.g. ~/cluny
CLUNY_DATA_DIR=.cluny

# Catalog folder under CLUNY_DATA_DIR (default: library). Use BRAIN, etc.
# CLUNY_CATALOG_DIR=library

# SQLite filename inside that folder (default: library.sqlite). Example with BRAIN folder:
# CLUNY_LIBRARY_SQLITE=brain.sqlite

# PDF text layer vs OCR: auto (try text, then OCR if empty) | always | never
# Requires Tesseract on PATH (e.g. brew install tesseract) plus pymupdf/pytesseract/Pillow.
CLUNY_PDF_OCR=auto

# URL fetching (cluny add-url)
# open = allow all hosts except blocklist | restricted = only CLUNY_URL_ALLOWLIST
CLUNY_URL_MODE=open
# Comma-separated host patterns (e.g. example.com,*.edu)
# CLUNY_URL_ALLOWLIST=
# CLUNY_URL_BLOCKLIST=facebook.com,doubleclick.net
CLUNY_URL_MAX_BYTES=15000000
CLUNY_URL_TIMEOUT_SEC=30
# CLUNY_URL_USER_AGENT=Cluny/0.1
